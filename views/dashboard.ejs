<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - CHATRIX</title>
    <link rel="stylesheet" href="/CSS/style.css">
</head>
<body class="dashboard-page">
    <a href="/profile" class="top-profile-link">View Profile</a>

    <div class="container container-wide">
        <h1>Dashboard</h1>
        <p class="subtitle">Welcome back, <strong><%= username %></strong></p>

        <div class="stats-grid">
            <div class="stat-card">
                <span class="stat-value"><%= friendsCount %></span>
                <span class="stat-label">Friends</span>
            </div>
            <div class="stat-card">
                <span class="stat-value"><%= pendingRequestsCount %></span>
                <span class="stat-label">Pending Requests</span>
            </div>
        </div>

        <div class="info-card">
            <p><span class="detail-label">Signed in as</span><br><%= email %></p>
        </div>

        <nav class="nav-links">
            <a href="/profile/edit"><button type="button">Edit Profile</button></a>
            <a href="/logout"><button type="button" class="btn-secondary">Logout</button></a>
        </nav>
    </div>
</body>
</html>
