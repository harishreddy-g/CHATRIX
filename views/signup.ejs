<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Signup</title>
    <link rel="stylesheet" href="/CSS/style.css">
</head>

<body>
    <div class="container">
        <h1>Create Account</h1>
        <h3>Enter signup details</h3>
        <form action="/signup" method="post" enctype="multipart/form-data">
            <label for="Username">Username</label>
            <input id="Username" name="username" type="text" placeholder="Enter username">
            <label for="Email">Email</label>
            <input id="Email" name="email" type="email" placeholder="Enter mail address">
            <label for="Password">Password</label>
            <input id="Password" name="password" type="password" placeholder="Enter Password">
            <label><input id="showpassword" type="checkbox"> Show password</label>
            <label for="Profile">Profile picture</label>
            <input id="Profile" name="profilePicture" type="file" accept="image/jpeg,image/png,image/gif,image/webp">
            <p class="form-note">Image files only (JPEG, PNG, GIF, or WebP).</p>
            <button id="createBtn" type="submit">Create account</button>
        </form>
        <p id="message"></p>
        <nav class="nav-links">
            <a href="/"><button type="button">Home</button></a>
            <a href="login"><button type="button">Login</button></a>
        </nav>
    </div>

    <script src="/JS/script.js"></script>
</body>

</html>