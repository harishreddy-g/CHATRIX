<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Signup</title>
    <link rel="stylesheet" href="/CSS/style.css">
</head>

<body>
    <h1>Create Account</h1>
    <div>
        <h3><b>Enter signup details</b></h3>
        <form>
            <label>Username</label>
            <input id="Username" type="text" placeholder="Enter username"><br><br>
            <label>Email:</label>
            <input id="Email" type="text" placeholder="Enter mail address"><br><br>
            <label>Password</label>
            <input id="Password" type="password"  placeholder="Enter Password"><br><br>
            <label><input id="showpassword" type="checkbox"> Show password</label><br><br>
            <label>Profile picture</label>
            <input id="Profile" type="file"><br><br>
            <button id="createBtn" type="submit">create account</button>
        </form><br>
        <p id="message" style="color: brown;"></p><br><br>
        <button><a href="/">Home</a> </button><br><br>
        <button><a href="login">Login</a> </button>
    </div>

    <script src="/JS/script.js"></script>
</body>

</html>